  "_meta": {
    "site_id": "699f435633df7bdd84c75b23",
    "component_id": "699f435733df7bdd84c75b6c",
    "extracted": "2026-02-26",
    "description": "1:1 Reproduktionsprofil der section_team Sektion inkl. aller CSS-Klassen, Responsivität und Hover-Animation",
    "animation_note": "Hover-Effekt: .team_content fährt von unten hoch und füllt die gesamte Kachel aus. Implementierung via Custom CSS (feste Starthöhe statt height:auto).",
    "animation_css": {
      "description": "Einbinden via Site Settings → Custom Code → Footer Code oder als lokales Embed-Element in der Section",
      "important": "7.5rem ist der Startwert – anpassen bis Role+Name exakt sichtbar sind. Ggf. per @media für mobile Breakpoints feinjustieren.",
      "code": ".team_content { display: flex; height: 7.5rem; overflow: hidden; transition: height 0.4s ease-out; } .team_item:hover .team_content { height: 100%; } .team_description { opacity: 0; transition: opacity 0.25s ease-out 0.15s; } .team_item:hover .team_description { opacity: 1; } @media (max-width: 768px) { .team_content { height: 8rem; } }",
      "code_formatted": [
        ".team_content {",
        "  display: flex;",
        "  height: 7.5rem;           /* ← anpassen bis Role+Name genau passt */",
        "  overflow: hidden;",
        "  transition: height 0.4s ease-out;",
        "}",
        ".team_item:hover .team_content {",
        "  height: 100%;",
        "}",
        ".team_description {",
        "  opacity: 0;",
        "  transition: opacity 0.25s ease-out 0.15s; /* 0.15s Verzögerung */",
        "}",
        ".team_item:hover .team_description {",
        "  opacity: 1;",
        "}",
        "@media (max-width: 768px) {",
        "  .team_content { height: 8rem; }",
        "}"
      ],
      "why_fixed_height": "height:auto ist nicht animierbar. Durch eine feste Starthöhe (z.B. 7.5rem) wächst das Element organisch von unten nach oben – kein translateY-Workaround nötig.",
      "webflow_note": "In Webflow muss height:auto im Style .team_content durch den festen Wert (7.5rem) ersetzt werden – entweder direkt im Style-Panel oder via Custom CSS-Override."
    }
  },

